# Normalize line endings to LF in the repository; check out as-is on all platforms.
* text=auto eol=lf

# Explicitly LF for source files
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.json text eol=lf
*.html text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
